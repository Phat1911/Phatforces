PORT=8080
DB_URL=postgres://photcot:photcot123@localhost:5432/photcot?sslmode=disable
REDIS_URL=localhost:6379
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=524288000

# Resend Email (for OTP verification)
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=Phatforces <onboarding@resend.dev>

# OTP / Verification code policy
# How long a code is valid before expiring
OTP_EXPIRY_MINUTES=10
# Max code requests per email per hour (rate limit)
OTP_MAX_REQUESTS_PER_HOUR=3
# Seconds the frontend must wait before requesting another code
OTP_RESEND_COOLDOWN_SECONDS=60
